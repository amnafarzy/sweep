{
  "name": "sweep",
  "version": "1.0.0",
  "description": "A free, open Mac cleanup utility — scan caches, free RAM, find large files, manage login items, and empty trash.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test && npm run check:renderer",
    "check:renderer": "node scripts/check-renderer.mjs",
    "dist": "electron-builder --mac"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.sweep.cleaner",
    "productName": "Sweep",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": ["dmg"]
    },
    "dmg": {
      "icon": "build/icon.icns",
      "background": "build/dmg-background.png",
      "window": { "width": 540, "height": 380 },
      "iconSize": 96,
      "contents": [
        { "x": 150, "y": 200, "type": "file" },
        { "x": 390, "y": 200, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
